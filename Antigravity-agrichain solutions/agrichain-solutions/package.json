    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "contracts:deploy": "node scripts/deploy-contracts.mjs"
  },
  "dependencies": {
    "next": "14.2.9",
    "react": "18.2.0",
