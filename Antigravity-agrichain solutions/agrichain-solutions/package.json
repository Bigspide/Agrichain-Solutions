{
  "name": "agrichain-solutions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./server.mjs')\"",
    "lint": "eslint src next.config.ts middleware.ts prisma.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"src/__node_tests__/*.test.mjs\"",
